{
  "name": "daily-gm-reporter",
  "version": "1.0.0",
  "type": "module",
  "description": "Discord daily GM count reporter bot",
  "scripts": {
    "type-check": "tsc --noEmit",
    "start": "tsx scripts/daily-count.ts",
    "start:dry-run": "DRY_RUN=true tsx scripts/daily-count.ts",
    "start:v2": "tsx scripts/daily-count-v2.ts",
    "post": "tsx scripts/post.ts",
    "surprise": "tsx scripts/interval-post.ts",
    "surprise:test": "DRY_RUN=true INTERVAL_MINUTES=0.16 START_JST=16:01 tsx scripts/interval-post.ts",
    "test": "find tests -name '*.test.ts' -exec tsx --test {} +",
    "test:watch": "find tests -name '*.test.ts' -exec tsx --test --watch {} +"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.100.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "discord",
    "bot",
    "github-actions"
  ],
  "author": "",
  "license": "MIT"
}
